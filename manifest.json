<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0a0a0a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="FullBody x3">
<link rel="manifest" href="manifest.json">
<title>FullBody x3</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0a0a0a;--bg2:#141414;--bg3:#1e1e1e;--bg4:#252525;
    --border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.14);
    --accent:#d4f53c;--accent2:#a8c42e;
    --text:#f0f0f0;--muted:#777;
    --push:#f97316;--pull:#3b82f6;--legs:#a855f7;
    --radius:16px;
    --fd:'Bebas Neue',sans-serif;--fb:'DM Sans',sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:var(--fb)}
  .screen{display:none;flex-direction:column;height:100vh;overflow:hidden}
  .screen.active{display:flex}

  /* HOME */
  .home-header{padding:52px 24px 20px;background:linear-gradient(180deg,#111 0%,transparent 100%)}
  .home-logo{font-family:var(--fd);font-size:52px;letter-spacing:2px;color:var(--accent);line-height:1}
  .home-sub{font-size:13px;color:var(--muted);margin-top:4px;letter-spacing:.04em}
  .week-strip{display:flex;gap:6px;padding:0 24px 20px}
  .week-day{flex:1;height:4px;border-radius:2px;background:var(--bg3);transition:background .3s}
  .week-day.done{background:var(--accent)}
  .week-day.today{background:var(--accent);opacity:.5;animation:pbar 1.5s ease-in-out infinite}
  @keyframes pbar{0%,100%{opacity:.5}50%{opacity:1}}
  .days-scroll{flex:1;overflow-y:auto;padding:0 16px 100px;scrollbar-width:none}
  .days-scroll::-webkit-scrollbar{display:none}
  .day-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:12px;cursor:pointer;transition:transform .15s;position:relative;overflow:hidden}
  .day-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
  .day-card.dayA::before{background:var(--push)}
  .day-card.dayB::before{background:var(--pull)}
  .day-card.dayC::before{background:var(--legs)}
  .day-card:active{transform:scale(.98)}
  .day-card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
  .day-label{font-family:var(--fd);font-size:28px;letter-spacing:1px}
  .day-tag{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:4px 10px;border-radius:20px;background:var(--bg3);color:var(--muted)}
  .day-tag.dayA{background:rgba(249,115,22,.15);color:var(--push)}
  .day-tag.dayB{background:rgba(59,130,246,.15);color:var(--pull)}
  .day-tag.dayC{background:rgba(168,85,247,.15);color:var(--legs)}
  .day-ex-list{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px}
  .ex-chip{font-size:11px;padding:3px 9px;border-radius:20px;background:var(--bg3);color:var(--muted);border:1px solid var(--border)}
  .day-meta{display:flex;gap:16px}
  .day-meta span{font-size:12px;color:var(--muted)}
  .day-meta strong{color:var(--text)}
  .start-btn-icon{position:absolute;bottom:20px;right:20px;width:36px;height:36px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center}
  .start-btn-icon svg{width:16px;height:16px;fill:#0a0a0a}

  /* WORKOUT */
  #workout{background:var(--bg)}
  .workout-top{display:flex;align-items:center;gap:12px;padding:52px 20px 16px}
  .back-btn{width:40px;height:40px;border-radius:50%;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0}
  .back-btn svg{width:20px;height:20px;stroke:var(--text);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .workout-title-wrap{flex:1}
  .workout-title{font-family:var(--fd);font-size:26px;letter-spacing:1px}
  .workout-sub{font-size:12px;color:var(--muted);margin-top:2px}
  .prog-wrap{height:3px;background:var(--bg3);margin:0 20px;border-radius:2px}
  .prog-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .4s}
  .phase-lbl{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding:14px 20px 6px}
  .workout-body{flex:1;overflow-y:auto;padding:0 16px;scrollbar-width:none}
  .workout-body::-webkit-scrollbar{display:none}

  /* Exercise cards */
  .ex-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:10px;transition:border-color .2s,background .2s}
  .ex-card.active-ex{border-color:var(--accent);background:linear-gradient(135deg,rgba(212,245,60,.06) 0%,var(--bg2) 60%)}
  .ex-card.done-ex{opacity:.38}
  .ex-card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
  .ex-num{font-size:11px;color:var(--muted);font-weight:500;margin-bottom:3px}
  .ex-title{font-family:var(--fd);font-size:23px;letter-spacing:.5px;line-height:1}
  .ex-note{font-size:12px;color:var(--muted);margin-top:4px}
  .edit-btn{flex-shrink:0;width:34px;height:34px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer}
  .edit-btn svg{width:14px;height:14px;stroke:var(--muted);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .ex-badges{display:flex;gap:6px;margin-top:10px;flex-wrap:wrap}
  .badge{font-size:12px;font-weight:600;padding:4px 10px;border-radius:20px;background:var(--bg3);color:var(--text)}
  .badge.s{background:rgba(212,245,60,.12);color:var(--accent)}
  .badge.r{background:rgba(255,255,255,.07);color:var(--text)}
  .badge.t{background:rgba(255,180,50,.1);color:#ffb432}
  .badge.c{background:rgba(168,85,247,.12);color:#c084fc}
  .series-dots{display:flex;gap:8px;margin-top:12px}
  .dot{width:10px;height:10px;border-radius:50%;background:var(--bg3);border:1.5px solid var(--border);transition:background .2s,border-color .2s}
  .dot.done{background:var(--accent);border-color:var(--accent)}
  .dot.current{background:transparent;border-color:var(--accent);animation:pdot .8s ease-in-out infinite}
  @keyframes pdot{0%,100%{transform:scale(1)}50%{transform:scale(1.35)}}

  /* REST OVERLAY */
  #rest-overlay{display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,.93);flex-direction:column;align-items:center;justify-content:center;text-align:center}
  #rest-overlay.show{display:flex}
  .rest-lbl{font-size:13px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:24px}
  .rest-ring-wrap{position:relative;width:200px;height:200px;margin-bottom:24px}
  .ring-bg{fill:none;stroke:var(--bg3);stroke-width:8}
  .ring-fg{fill:none;stroke:var(--accent);stroke-width:8;stroke-linecap:round;transform-origin:center;transform:rotate(-90deg);transition:stroke-dashoffset .9s linear}
  .rest-time-big{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
  .rest-num{font-family:var(--fd);font-size:72px;color:var(--accent);line-height:1}
  .rest-secs{font-size:14px;color:var(--muted)}
  .rest-next-lbl{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
  .rest-next-name{font-family:var(--fd);font-size:26px;color:var(--text)}
  .rest-skip{margin-top:32px;background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:12px 32px;border-radius:40px;font-family:var(--fb);font-size:14px;font-weight:500;cursor:pointer}

  /* BOTTOM CTA */
  .bottom-action{padding:16px 20px 36px;background:linear-gradient(0deg,var(--bg) 60%,transparent 100%)}
  .cta-btn{width:100%;padding:18px;background:var(--accent);color:#0a0a0a;border:none;border-radius:14px;font-family:var(--fd);font-size:22px;letter-spacing:1px;cursor:pointer;transition:transform .1s,background .15s}
  .cta-btn:active{transform:scale(.98);background:var(--accent2)}

  /* EDIT DRAWER */
  #edit-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.65)}
  #edit-overlay.show{display:block}
  #edit-drawer{position:fixed;bottom:0;left:0;right:0;z-index:201;background:var(--bg2);border-radius:20px 20px 0 0;border-top:1px solid var(--border2);padding-bottom:40px;transform:translateY(100%);transition:transform .3s cubic-bezier(.32,1,.56,1);max-height:90vh;overflow-y:auto}
  #edit-drawer.open{transform:translateY(0)}
  .drawer-handle{width:36px;height:4px;border-radius:2px;background:var(--bg4);margin:12px auto 20px}
  .drawer-title{font-family:var(--fd);font-size:20px;letter-spacing:1px;padding:0 20px 16px;border-bottom:1px solid var(--border);color:var(--accent)}
  .field-group{padding:18px 20px 0}
  .field-label{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
  .field-input{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:10px;padding:12px 14px;color:var(--text);font-family:var(--fb);font-size:15px;outline:none;transition:border-color .15s}
  .field-input:focus{border-color:var(--accent)}
  .stepper-row{display:flex;align-items:center;gap:0;background:var(--bg3);border-radius:12px;border:1px solid var(--border2);overflow:hidden}
  .stepper-val{flex:1;text-align:center;font-family:var(--fd);font-size:34px;color:var(--text);padding:10px 0}
  .step-btn{width:56px;height:56px;background:transparent;border:none;color:var(--text);font-size:26px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .1s;flex-shrink:0}
  .step-btn:active{background:var(--bg4)}
  .rest-presets{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
  .preset-btn{padding:6px 14px;border-radius:20px;background:var(--bg3);border:1px solid var(--border);color:var(--muted);font-size:13px;cursor:pointer;transition:all .1s}
  .preset-btn.sel{background:rgba(212,245,60,.15);color:var(--accent);border-color:rgba(212,245,60,.4)}
  .drawer-actions{display:flex;gap:10px;padding:20px 20px 0}
  .drawer-save{flex:1;padding:14px;background:var(--accent);color:#0a0a0a;border:none;border-radius:12px;font-family:var(--fd);font-size:20px;letter-spacing:1px;cursor:pointer}
  .drawer-cancel{padding:14px 20px;background:var(--bg3);border:1px solid var(--border);color:var(--muted);border-radius:12px;font-family:var(--fb);font-size:14px;font-weight:500;cursor:pointer}
  .reset-link{text-align:center;padding:14px 20px 0;font-size:12px;color:var(--muted);cursor:pointer;text-decoration:underline}

  /* DONE */
  #done{align-items:center;justify-content:center;text-align:center;background:var(--bg)}
  .done-icon{font-size:64px;margin-bottom:24px}
  .done-title{font-family:var(--fd);font-size:52px;letter-spacing:2px;color:var(--accent);margin-bottom:8px}
  .done-sub{font-size:15px;color:var(--muted);margin-bottom:32px}
  .done-stats{display:flex;gap:24px;margin-bottom:40px}
  .done-stat{text-align:center}
  .done-stat-num{font-family:var(--fd);font-size:36px;color:var(--text)}
  .done-stat-lbl{font-size:12px;color:var(--muted);margin-top:2px}
  .done-home-btn{background:var(--accent);color:#0a0a0a;border:none;padding:16px 48px;border-radius:40px;font-family:var(--fd);font-size:22px;letter-spacing:1px;cursor:pointer}

  /* INSTALL */
  #install-banner{display:none;position:fixed;bottom:0;left:0;right:0;z-index:300;background:var(--bg2);border-top:1px solid var(--border);padding:16px 20px 36px;flex-direction:column;gap:12px}
  #install-banner.show{display:flex}
  .install-text{font-size:14px;color:var(--text)}
  .install-text span{color:var(--accent);font-weight:600}
  .install-btns{display:flex;gap:10px}
  .install-btn{flex:1;padding:12px;border-radius:10px;border:none;font-family:var(--fb);font-size:14px;font-weight:600;cursor:pointer}
  .install-btn.p{background:var(--accent);color:#0a0a0a}
  .install-btn.s{background:var(--bg3);color:var(--muted)}
</style>
</head>
<body>

<!-- HOME -->
<div class="screen active" id="home">
  <div class="home-header">
    <div class="home-logo">FULLBODY</div>
    <div class="home-sub">3 SÉANCES · 45 MIN · FRÉQUENCE 3×</div>
  </div>
  <div class="week-strip" id="week-strip"></div>
  <div class="days-scroll" id="days-list"></div>
</div>

<!-- WORKOUT -->
<div class="screen" id="workout">
  <div class="workout-top">
    <div class="back-btn" onclick="goHome()">
      <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
    </div>
    <div class="workout-title-wrap">
      <div class="workout-title" id="wk-title">SÉANCE A</div>
      <div class="workout-sub" id="wk-sub">Push + Squat</div>
    </div>
  </div>
  <div class="prog-wrap"><div class="prog-fill" id="prog-fill" style="width:0%"></div></div>
  <div class="workout-body" id="workout-body"></div>
  <div class="bottom-action">
    <button class="cta-btn" id="main-cta" onclick="handleCTA()">COMMENCER</button>
  </div>
</div>

<!-- REST OVERLAY -->
<div id="rest-overlay">
  <div class="rest-lbl">TEMPS DE REPOS</div>
  <div class="rest-ring-wrap">
    <svg width="200" height="200" viewBox="0 0 200 200">
      <circle class="ring-bg" cx="100" cy="100" r="88"/>
      <circle class="ring-fg" id="ring-fill" cx="100" cy="100" r="88"/>
    </svg>
    <div class="rest-time-big">
      <div class="rest-num" id="rest-num">90</div>
      <div class="rest-secs">secondes</div>
    </div>
  </div>
  <div class="rest-next-lbl">PROCHAIN</div>
  <div class="rest-next-name" id="rest-next">—</div>
  <button class="rest-skip" onclick="skipRest()">PASSER LE REPOS</button>
</div>

<!-- EDIT DRAWER -->
<div id="edit-overlay" onclick="closeEdit()"></div>
<div id="edit-drawer">
  <div class="drawer-handle"></div>
  <div class="drawer-title" id="edit-drawer-title">MODIFIER</div>

  <div class="field-group">
    <div class="field-label">Nom de l'exercice</div>
    <input class="field-input" id="edit-name" type="text" autocomplete="off">
  </div>

  <div class="field-group">
    <div class="field-label">Reps / durée</div>
    <input class="field-input" id="edit-reps" type="text" autocomplete="off" placeholder="ex: 8–12 reps">
  </div>

  <div class="field-group">
    <div class="field-label">Nombre de séries</div>
    <div class="stepper-row">
      <button class="step-btn" onclick="stepSeries(-1)">−</button>
      <div class="stepper-val" id="edit-series-val">3</div>
      <button class="step-btn" onclick="stepSeries(1)">+</button>
    </div>
  </div>

  <div class="field-group">
    <div class="field-label">Temps de repos (secondes)</div>
    <div class="stepper-row">
      <button class="step-btn" onclick="stepRest(-15)">−</button>
      <div class="stepper-val" id="edit-rest-val">90</div>
      <button class="step-btn" onclick="stepRest(15)">+</button>
    </div>
    <div class="rest-presets">
      <button class="preset-btn" onclick="setRestPreset(0)">Pas de repos</button>
      <button class="preset-btn" onclick="setRestPreset(45)">45s</button>
      <button class="preset-btn" onclick="setRestPreset(60)">60s</button>
      <button class="preset-btn" onclick="setRestPreset(90)">90s</button>
      <button class="preset-btn" onclick="setRestPreset(120)">2 min</button>
    </div>
  </div>

  <div class="drawer-actions">
    <button class="drawer-cancel" onclick="closeEdit()">Annuler</button>
    <button class="drawer-save" onclick="saveEdit()">SAUVEGARDER</button>
  </div>
  <div class="reset-link" onclick="resetExercise()">Réinitialiser aux valeurs par défaut</div>
</div>

<!-- DONE -->
<div class="screen" id="done">
  <div class="done-icon">💪</div>
  <div class="done-title">SÉANCE<br>TERMINÉE</div>
  <div class="done-sub" id="done-sub">Bien joué !</div>
  <div class="done-stats">
    <div class="done-stat"><div class="done-stat-num" id="done-series">0</div><div class="done-stat-lbl">séries</div></div>
    <div class="done-stat"><div class="done-stat-num" id="done-exos">0</div><div class="done-stat-lbl">exercices</div></div>
    <div class="done-stat"><div class="done-stat-num" id="done-time">0</div><div class="done-stat-lbl">minutes</div></div>
  </div>
  <button class="done-home-btn" onclick="goHome()">RETOUR</button>
</div>

<!-- INSTALL -->
<div id="install-banner">
  <div class="install-text">📲 <span>Installer l'app</span> sur ton écran d'accueil</div>
  <div class="install-btns">
    <button class="install-btn p" id="install-yes">Installer</button>
    <button class="install-btn s" id="install-no">Plus tard</button>
  </div>
</div>

<script>
// ═══════════════════════════════
//  DEFAULT DATA
// ═══════════════════════════════
const DEFAULT_DAYS = [
  {
    id:'A', label:'SÉANCE A', sub:'Push + Squat', day:'Lundi', cls:'dayA', tagLabel:'PUSH',
    exercises:[
      {name:'Échauffement',       note:'Cardio léger + mobilité articulaire',              series:1, reps:'5 min',        rest:0,   phase:'ÉCHAUFFEMENT'},
      {name:'Squat barre',        note:'Mouvement roi du bas du corps',                    series:4, reps:'6–8 reps',     rest:120, phase:'BLOC 1 — POUSSER + JAMBES'},
      {name:'Développé couché',   note:'Prise légèrement + large que les épaules',         series:4, reps:'6–8 reps',     rest:120, phase:null},
      {name:'Tirage horizontal',  note:'Coudes rentrés, omoplate serrée',                  series:3, reps:'10–12 reps',   rest:0,   phase:'CIRCUIT FINAL — SANS REPOS', circuit:true},
      {name:'Presse épaules',     note:'Contrôle sur la descente',                         series:3, reps:'10–12 reps',   rest:0,   phase:null, circuit:true},
      {name:'Curl biceps',        note:'Supination en fin de mouvement',                   series:2, reps:'12–15 reps',   rest:60,  phase:null, circuit:true},
    ]
  },
  {
    id:'B', label:'SÉANCE B', sub:'Pull + Charnière', day:'Mercredi', cls:'dayB', tagLabel:'PULL',
    exercises:[
      {name:'Échauffement',               note:'Cardio léger + mobilité articulaire',      series:1, reps:'5 min',       rest:0,   phase:'ÉCHAUFFEMENT'},
      {name:'Soulevé de terre roumain',   note:'Hanches en arrière, dos neutre',           series:4, reps:'6–8 reps',    rest:120, phase:'BLOC 1 — TIRER + POSTÉRIEUR'},
      {name:'Tractions',                  note:'Amplitude complète, prise pronation/neutre',series:4,reps:'6–10 reps',   rest:120, phase:null},
      {name:'Développé incliné haltères', note:'Angle ~30°, coudes à 45°',                series:3, reps:'10–12 reps',  rest:0,   phase:'CIRCUIT FINAL — SANS REPOS', circuit:true},
      {name:'Rowing 1 bras',              note:'Appui sur banc, coude vers le plafond',   series:3, reps:'10–12 reps',  rest:0,   phase:null, circuit:true},
      {name:'Extension triceps',          note:'Coudes fixes, bras tendus en bas',         series:2, reps:'12–15 reps',  rest:60,  phase:null, circuit:true},
    ]
  },
  {
    id:'C', label:'SÉANCE C', sub:'Gainage + Fréquence', day:'Vendredi', cls:'dayC', tagLabel:'LEGS',
    exercises:[
      {name:'Échauffement',          note:'Cardio léger + mobilité articulaire',           series:1, reps:'5 min',        rest:0,   phase:'ÉCHAUFFEMENT'},
      {name:'Hip thrust barre',      note:"Orteils légèrement vers l'extérieur",           series:4, reps:'8–10 reps',    rest:90,  phase:'BLOC 1 — FESSES + DOS'},
      {name:'Tirage vertical large', note:'Isole bien le grand dorsal',                    series:4, reps:'8–10 reps',    rest:90,  phase:null},
      {name:'Fentes marchées',       note:'Genou arrière proche du sol, buste droit',      series:3, reps:'10 reps/jambe',rest:90,  phase:'BLOC 2 — FULL BODY + CORE'},
      {name:'Élévations latérales',  note:'Coudes légèrement fléchis, contrôle descente', series:3, reps:'12–15 reps',   rest:60,  phase:null},
      {name:'Gainage planche',       note:'Planche, side plank ou crunch chargé',          series:3, reps:'30–45 sec',    rest:45,  phase:null},
    ]
  }
];

// ═══════════════════════════════
//  CUSTOM STORAGE
// ═══════════════════════════════
function getCustom() { try { return JSON.parse(localStorage.getItem('wk_custom')||'{}'); } catch { return {}; } }
function saveCustom(c) { localStorage.setItem('wk_custom', JSON.stringify(c)); }
function cKey(dayId, i) { return `${dayId}_${i}`; }
function getEx(dayId, i) {
  const def = DEFAULT_DAYS.find(d=>d.id===dayId).exercises[i];
  const ov = getCustom()[cKey(dayId,i)];
  return ov ? {...def,...ov} : {...def};
}
function getDayExs(dayId) {
  return DEFAULT_DAYS.find(d=>d.id===dayId).exercises.map((_,i)=>getEx(dayId,i));
}

// ═══════════════════════════════
//  HISTORY
// ═══════════════════════════════
function getHistory() { try { return JSON.parse(localStorage.getItem('wk_history')||'{}'); } catch { return {}; } }
function saveHistory(h) { localStorage.setItem('wk_history', JSON.stringify(h)); }
function markDone(id) {
  const h=getHistory(), t=new Date().toDateString();
  if(!h[id])h[id]=[];
  if(!h[id].includes(t))h[id].push(t);
  if(h[id].length>30)h[id]=h[id].slice(-30);
  saveHistory(h);
}
function isDoneThisWeek(id) {
  const h=getHistory(); if(!h[id])return false;
  const now=new Date(), mon=new Date(now);
  mon.setDate(now.getDate()-((now.getDay()+6)%7)); mon.setHours(0,0,0,0);
  return h[id].some(d=>new Date(d)>=mon);
}

// ═══════════════════════════════
//  STATE
// ═══════════════════════════════
let currentDay=null, currentExIdx=0, seriesDone={};
let restTimer=null, restTotal=0, restMoveNext=false;
let workoutStartTime=null, totalSeriesDone=0;
let editDayId=null, editExIdx=null, editSeries=3, editRest=90;

// ═══════════════════════════════
//  HOME
// ═══════════════════════════════
function renderHome() {
  const strip=document.getElementById('week-strip'); strip.innerHTML='';
  const dow=(new Date().getDay()+6)%7;
  for(let i=0;i<7;i++){const el=document.createElement('div');el.className='week-day'+(i<dow?' done':i===dow?' today':'');strip.appendChild(el);}
  const list=document.getElementById('days-list'); list.innerHTML='';
  DEFAULT_DAYS.forEach(day=>{
    const done=isDoneThisWeek(day.id), exs=getDayExs(day.id);
    const tot=exs.reduce((a,e)=>a+(e.name==='Échauffement'?0:e.series),0);
    const card=document.createElement('div');
    card.className=`day-card ${day.cls}`;
    card.innerHTML=`
      <div class="day-card-top">
        <div><div class="day-label">${day.label}</div><div style="font-size:13px;color:var(--muted);margin-top:2px">${day.sub}</div></div>
        <div class="day-tag ${day.cls}">${done?'✓ FAIT':day.tagLabel}</div>
      </div>
      <div class="day-ex-list">${exs.filter(e=>e.name!=='Échauffement').map(e=>`<span class="ex-chip">${e.name}</span>`).join('')}</div>
      <div class="day-meta"><span>⏱ <strong>~45 min</strong></span><span>🔁 <strong>${tot} séries</strong></span><span>📅 <strong>${day.day}</strong></span></div>
      <div class="start-btn-icon"><svg viewBox="0 0 24 24"><path d="M8 5l11 7-11 7V5z"/></svg></div>`;
    card.onclick=()=>startWorkout(day);
    list.appendChild(card);
  });
}

// ═══════════════════════════════
//  WORKOUT
// ═══════════════════════════════
function startWorkout(day) {
  currentDay=day; currentExIdx=0; seriesDone={}; totalSeriesDone=0; workoutStartTime=Date.now();
  document.getElementById('wk-title').textContent=day.label;
  document.getElementById('wk-sub').textContent=day.sub;
  showScreen('workout'); renderWorkout(); updateCTA();
}

function renderWorkout() {
  const body=document.getElementById('workout-body'); body.innerHTML='';
  const exs=getDayExs(currentDay.id);
  exs.forEach((ex,i)=>{
    const isDone=(seriesDone[i]||0)>=ex.series, isActive=i===currentExIdx;
    let dots='';
    if(ex.series>1){
      dots='<div class="series-dots">';
      for(let s=0;s<ex.series;s++){const d=s<(seriesDone[i]||0),c=isActive&&s===(seriesDone[i]||0);dots+=`<div class="dot${d?' done':''}${c?' current':''}"></div>`;}
      dots+='</div>';
    }
    const restB=ex.rest>0?`<span class="badge t">⏱ ${ex.rest}s repos</span>`:'';
    const circB=ex.circuit?`<span class="badge c">⚡ CIRCUIT</span>`:'';
    const phaseEl=ex.phase?`<div class="phase-lbl">${ex.phase}</div>`:'';
    const checkEl=isDone?'<div style="font-size:22px;flex-shrink:0">✓</div>':'';
    const editBtn=ex.name!=='Échauffement'
      ?`<button class="edit-btn" onclick="openEdit('${currentDay.id}',${i},event)"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>`:'';
    body.innerHTML+=`${phaseEl}
    <div class="ex-card${isActive?' active-ex':''}${isDone?' done-ex':''}" id="ex-card-${i}">
      <div class="ex-card-top">
        <div style="flex:1;min-width:0">
          <div class="ex-num">EXERCICE ${i+1} / ${exs.length}</div>
          <div class="ex-title">${ex.name.toUpperCase()}</div>
          <div class="ex-note">${ex.note}</div>
        </div>
        ${checkEl}${editBtn}
      </div>
      <div class="ex-badges"><span class="badge s">${ex.series}× séries</span><span class="badge r">${ex.reps}</span>${restB}${circB}</div>
      ${dots}
    </div>`;
  });
  setTimeout(()=>{const el=document.getElementById(`ex-card-${currentExIdx}`);if(el)el.scrollIntoView({behavior:'smooth',block:'center'});},100);
  const tot=exs.reduce((a,e)=>a+e.series,0);
  const done=Object.values(seriesDone).reduce((a,v)=>a+v,0);
  document.getElementById('prog-fill').style.width=(done/tot*100)+'%';
}

function handleCTA() {
  const exs=getDayExs(currentDay.id), ex=exs[currentExIdx];
  const done=seriesDone[currentExIdx]||0;
  seriesDone[currentExIdx]=done+1; totalSeriesDone++;
  const newDone=seriesDone[currentExIdx];
  if(newDone>=ex.series){
    if(currentExIdx<exs.length-1){
      if(ex.rest>0){startRest(ex.rest,exs[currentExIdx+1].name,true);}
      else{currentExIdx++;renderWorkout();updateCTA();}
    } else {finishWorkout();}
  } else {
    if(ex.rest>0){startRest(ex.rest,ex.name,false);}
    else{renderWorkout();updateCTA();}
  }
}

function updateCTA() {
  const btn=document.getElementById('main-cta');
  const exs=getDayExs(currentDay.id), ex=exs[currentExIdx];
  if(!ex)return;
  const done=seriesDone[currentExIdx]||0, rem=ex.series-done;
  if(done===0){btn.textContent=ex.name==='Échauffement'?"COMMENCER L'ÉCHAUFFEMENT":`DÉMARRER — ${ex.name.toUpperCase()}`;}
  else if(rem>0){btn.textContent=`SÉRIE ${done+1} / ${ex.series} — TERMINÉE`;}
  else{btn.textContent='EXERCICE SUIVANT →';}
  btn.className='cta-btn';
}

// ═══════════════════════════════
//  REST — uses absolute end time so background/screen-off doesn't pause it
// ═══════════════════════════════
const CIRC=2*Math.PI*88;
let restEndTime=null;

function startRest(sec,next,moveNext) {
  restTotal=sec; restMoveNext=moveNext;
  restEndTime=Date.now()+sec*1000;
  // Persist across page visibility changes
  localStorage.setItem('wk_rest', JSON.stringify({endTime:restEndTime,total:sec,moveNext,next,exIdx:currentExIdx}));
  document.getElementById('rest-next').textContent=next.toUpperCase();
  document.getElementById('ring-fill').style.strokeDasharray=CIRC;
  document.getElementById('rest-overlay').classList.add('show');
  clearInterval(restTimer);
  restTimer=setInterval(tickRest, 250); // tick 4× per sec for accuracy
  tickRest();
}

function tickRest() {
  const remaining=Math.max(0, Math.ceil((restEndTime-Date.now())/1000));
  document.getElementById('rest-num').textContent=remaining;
  document.getElementById('ring-fill').style.strokeDashoffset=CIRC*(1-remaining/restTotal);
  if(remaining<=3&&remaining>0) vibrate([40]);
  if(remaining<=0){
    clearInterval(restTimer);
    localStorage.removeItem('wk_rest');
    vibrate([200,100,200,100,400]); playBeep();
    document.getElementById('rest-overlay').classList.remove('show');
    if(restMoveNext) currentExIdx++;
    renderWorkout(); updateCTA();
  }
}

function skipRest() {
  clearInterval(restTimer);
  localStorage.removeItem('wk_rest');
  restEndTime=null;
  document.getElementById('rest-overlay').classList.remove('show');
  const exs=getDayExs(currentDay.id),ex=exs[currentExIdx];
  if((seriesDone[currentExIdx]||0)>=ex.series&&currentExIdx<exs.length-1)currentExIdx++;
  renderWorkout();updateCTA();
}

// Resume rest if app was in background
document.addEventListener('visibilitychange',()=>{
  if(document.visibilityState==='visible'&&restEndTime){
    clearInterval(restTimer);
    restTimer=setInterval(tickRest,250);
    tickRest();
  }
});

// On load, restore any in-progress rest (e.g. after full page reload)
function maybeRestoreRest() {
  try {
    const saved=localStorage.getItem('wk_rest');
    if(!saved||!currentDay) return;
    const r=JSON.parse(saved);
    if(r.exIdx!==currentExIdx) return;
    const remaining=Math.ceil((r.endTime-Date.now())/1000);
    if(remaining>0){
      restTotal=r.total; restMoveNext=r.moveNext; restEndTime=r.endTime;
      document.getElementById('rest-next').textContent=r.next.toUpperCase();
      document.getElementById('ring-fill').style.strokeDasharray=CIRC;
      document.getElementById('rest-overlay').classList.add('show');
      clearInterval(restTimer);
      restTimer=setInterval(tickRest,250);
      tickRest();
    } else {
      localStorage.removeItem('wk_rest');
    }
  } catch(e) { localStorage.removeItem('wk_rest'); }
}

// ═══════════════════════════════
//  EDIT DRAWER
// ═══════════════════════════════
function openEdit(dayId,exIdx,e) {
  e.stopPropagation();
  editDayId=dayId;editExIdx=exIdx;
  const ex=getEx(dayId,exIdx);
  editSeries=ex.series;editRest=ex.rest;
  document.getElementById('edit-drawer-title').textContent=ex.name.toUpperCase();
  document.getElementById('edit-name').value=ex.name;
  document.getElementById('edit-reps').value=ex.reps;
  document.getElementById('edit-series-val').textContent=editSeries;
  document.getElementById('edit-rest-val').textContent=editRest;
  updatePresets();
  document.getElementById('edit-overlay').classList.add('show');
  setTimeout(()=>document.getElementById('edit-drawer').classList.add('open'),10);
}
function closeEdit() {
  document.getElementById('edit-drawer').classList.remove('open');
  setTimeout(()=>document.getElementById('edit-overlay').classList.remove('show'),300);
}
function stepSeries(d){editSeries=Math.max(1,Math.min(10,editSeries+d));document.getElementById('edit-series-val').textContent=editSeries;}
function stepRest(d){editRest=Math.max(0,Math.min(300,editRest+d));document.getElementById('edit-rest-val').textContent=editRest;updatePresets();}
function setRestPreset(v){editRest=v;document.getElementById('edit-rest-val').textContent=v;updatePresets();}
function updatePresets(){
  const vals=[0,45,60,90,120];
  document.querySelectorAll('.preset-btn').forEach((btn,i)=>btn.classList.toggle('sel',vals[i]===editRest));
}
function saveEdit() {
  const name=document.getElementById('edit-name').value.trim()||getEx(editDayId,editExIdx).name;
  const reps=document.getElementById('edit-reps').value.trim()||getEx(editDayId,editExIdx).reps;
  const c=getCustom();
  c[cKey(editDayId,editExIdx)]={name,reps,series:editSeries,rest:editRest};
  saveCustom(c);closeEdit();
  if(currentDay&&currentDay.id===editDayId){renderWorkout();updateCTA();}else{renderHome();}
}
function resetExercise() {
  const c=getCustom();delete c[cKey(editDayId,editExIdx)];saveCustom(c);closeEdit();
  if(currentDay&&currentDay.id===editDayId){renderWorkout();updateCTA();}else renderHome();
}

// ═══════════════════════════════
//  AUDIO + VIBRATION
// ═══════════════════════════════
function vibrate(p){if('vibrate'in navigator)try{navigator.vibrate(p);}catch(e){}}
let audioCtx=null;
function getAudioCtx(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();return audioCtx;}
function playBeep(){try{const ctx=getAudioCtx(),o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.frequency.value=880;g.gain.setValueAtTime(.3,ctx.currentTime);g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.4);o.start();o.stop(ctx.currentTime+.4);}catch(e){}}

// ═══════════════════════════════
//  FINISH
// ═══════════════════════════════
function finishWorkout() {
  markDone(currentDay.id);
  const elapsed=Math.round((Date.now()-workoutStartTime)/60000);
  const exs=getDayExs(currentDay.id);
  document.getElementById('done-sub').textContent=`${currentDay.label} — ${currentDay.sub}`;
  document.getElementById('done-series').textContent=totalSeriesDone;
  document.getElementById('done-exos').textContent=exs.filter(e=>e.name!=='Échauffement').length;
  document.getElementById('done-time').textContent=elapsed;
  vibrate([100,50,100,50,500]);showScreen('done');
}

// ═══════════════════════════════
//  NAV
// ═══════════════════════════════
function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}
function goHome(){clearInterval(restTimer);document.getElementById('rest-overlay').classList.remove('show');showScreen('home');renderHome();}

// ═══════════════════════════════
//  PWA INSTALL
// ═══════════════════════════════
let deferredPrompt=null;
window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();deferredPrompt=e;if(!localStorage.getItem('install_dismissed'))document.getElementById('install-banner').classList.add('show');});
document.getElementById('install-yes').onclick=async()=>{document.getElementById('install-banner').classList.remove('show');if(deferredPrompt){deferredPrompt.prompt();await deferredPrompt.userChoice;deferredPrompt=null;}};
document.getElementById('install-no').onclick=()=>{document.getElementById('install-banner').classList.remove('show');localStorage.setItem('install_dismissed','1');};

// ═══════════════════════════════
//  INIT
// ═══════════════════════════════
renderHome();
// maybeRestoreRest() called after startWorkout if needed
document.body.addEventListener('touchstart',()=>{try{getAudioCtx();}catch(e){}},{once:true});
if('serviceWorker'in navigator)navigator.serviceWorker.register('sw.js').catch(()=>{});
</script>
</body>
</html>
